rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /smt_rolls/{rollId} {
      allow read, write: if request.auth != null;
    }

    match /smt_movements/{movId} {
      allow read, write: if request.auth != null;
    }

    match /boms/{bomId} {
      allow read, write: if request.auth != null;
    }

    match /bom_movements/{movId} {
      allow read, write: if request.auth != null;
    }

    match /subassemblies/{id} {
      allow read, write: if request.auth != null;
    }

    match /subassembly_movements/{id} {
      allow read, write: if request.auth != null;
    }

    match /hilight_rolls/{id} {
      allow read, write: if request.auth != null;
    }

    match /hilight_movements/{id} {
      allow read, write: if request.auth != null;
    }

    match /hls/{hlId} {
      allow read, write: if request.auth != null;
    }

    match /hl_movements/{movId} {
      allow read, write: if request.auth != null;
    }


    match /families/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}